# Scaleway Configuration
scaleway_project_id = "YOUR_SCALEWAY_PROJECT_ID"
scaleway_region     = "fr-par"
scaleway_zone       = "fr-par-1"
environment         = "prod"

# SSH Configuration
ssh_public_key      = "YOUR_SSH_PUBLIC_KEY"
allowed_ssh_ips     = ["YOUR_IP_ADDRESS/32"]

# Environment-dependent configuration
domain_name              = "api.example.com"
database_instance_type   = "DB-DEV-S"      # Options: DB-DEV-S, DB-GP-S, DB-GP-M, etc.
database_enable_ha       = false           # Enable for production
compute_instance_type    = "DEV1-M"        # Options: DEV1-S, DEV1-M, GP1-S, GP1-M, etc.

# Monitoring Configuration
grafana_auth_token = "YOUR_GRAFANA_AUTH_TOKEN"  # Token for Scaleway Cockpit monitoring