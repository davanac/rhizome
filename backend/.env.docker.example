# Rhizome Backend Docker Environment Configuration
# This file is used for testing with Docker Compose

# ======================
# Server Configuration
# ======================
NODE_ENV=production
PORT=3000
FRONTEND_URL=http://localhost:8000
JWT_SECRET=docker-test-jwt-secret-change-in-production

# ======================
# Database Configuration
# ======================
# Using docker-compose service name as host
DB_HOST=database
DB_PORT=5432
DB_USER=rhizome
DB_PASS=rhizome
DB_NAME=rhizome

# ======================
# Blockchain Configuration
# ======================
BLOCKCHAIN_ENV=sepolia_optimism

# Sepolia Optimism Testnet
SEPOLIA_OPTIMISM_TESTNET_RPC_URL=https://sepolia.optimism.io
SEPOLIA_OPTIMISM_TESTNET_CHAIN_ID=11155420
SEPOLIA_OPTIMISM_TESTNET_EXPLORER_URL=https://sepolia-optimistic.etherscan.io
SEPOLIA_OPTIMISM_TESTNET_CHAIN_NAME=SepoliaOptimism

# ======================
# Web3Auth Configuration
# ======================
# Get your Client ID from https://dashboard.web3auth.io
VITE_WEB3AUTH_CLIENT_ID=your_web3auth_client_id_here
VITE_WEB3AUTH_NETWORK=sapphire_devnet

# ======================
# Optional Configuration
# ======================
# External API URL for production (leave empty for Docker testing)
EXTERNAL_API_URL=

# Wallet Security (optional for testing)
# These are not required for Web3Auth-based authentication
MASTER_KEY_PASSWORD=
MASTER_KEY_ID=
