# Rhizome Backend Environment Configuration

# ======================
# Server Configuration
# ======================
NODE_ENV=development # development | production | remote
PORT=3000
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://username:password@localhost:5432/rhizome_db
JWT_SECRET=your-jwt-secret-key-here

# Optional: External API URL for image URLs (e.g., https://rhizome-api.sandbox.transcode.be)
# If not set, URLs will be generated based on the request hostname
EXTERNAL_API_URL=

# ======================
# Blockchain Configuration
# ======================
BLOCKCHAIN_ENV=sepolia_optimism # localhost | optimism | sepolia | sepolia_optimism | sepolia_base

# Localhost Testnet
LOCALHOST_TESTNET_RPC_URL=http://127.0.0.1:8545
LOCALHOST_TESTNET_CHAIN_ID=31337
LOCALHOST_TESTNET_EXPLORER_URL=
LOCALHOST_TESTNET_CHAIN_NAME=

# Sepolia Testnet (Ethereum)
SEPOLIA_TESTNET_RPC_URL=https://rpc-sepolia.rockx.com
SEPOLIA_TESTNET_CHAIN_ID=11155111
SEPOLIA_TESTNET_EXPLORER_URL=https://sepolia.etherscan.io
SEPOLIA_TESTNET_CHAIN_NAME=Sepolia

# Sepolia Optimism Testnet
SEPOLIA_OPTIMISM_TESTNET_RPC_URL=https://sepolia.optimism.io
SEPOLIA_OPTIMISM_TESTNET_CHAIN_ID=11155420
SEPOLIA_OPTIMISM_TESTNET_EXPLORER_URL=https://sepolia-optimistic.etherscan.io
SEPOLIA_OPTIMISM_TESTNET_CHAIN_NAME=SepoliaOptimism

# Optimism Mainnet
OPTIMISM_RPC_URL=https://mainnet.optimism.io/
OPTIMISM_CHAIN_ID=10
OPTIMISM_EXPLORER_URL=https://optimistic.etherscan.io/
OPTIMISM_CHAIN_NAME=OPMainnet

# Sepolia Base Testnet
SEPOLIA_BASE_TESTNET_RPC_URL=https://sepolia.base.org
SEPOLIA_BASE_TESTNET_CHAIN_ID=84532
SEPOLIA_BASE_TESTNET_EXPLORER_URL=https://sepolia-explorer.base.org
SEPOLIA_BASE_TESTNET_CHAIN_NAME=SepoliaBase

# ======================
# Wallet Security Configuration
# ======================
# Key identifier for encrypted wallet (not the private key itself)
PK=rhizome.your-domain.eth

# Password for encrypting/decrypting wallet keys
# SECURITY: Use a strong, unique password and consider using a secret management service
PASSWORD=your-secure-password-here

# Optional: Custom path for encrypted key file (cfr.json)
# If not set, defaults to ~/.rhizome/cfr.json for security
# CFR_FILE_PATH=/path/to/secure/location/cfr.json

# ======================
# Web3Auth Configuration
# ======================
# Get these from https://dashboard.web3auth.io
VITE_WEB3AUTH_CLIENT_ID=your-web3auth-client-id
VITE_WEB3AUTH_NETWORK=sapphire_devnet # sapphire_devnet | sapphire_mainnet
