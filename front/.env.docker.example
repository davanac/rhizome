# Rhizome Frontend Docker Build Configuration
# These variables are used during the Docker build process

# API URL - uses nginx proxy, so frontend calls /api which is proxied to backend:3000
VITE_API_URL=http://localhost:8000

# Frontend URL
VITE_FRONTEND_URL=http://localhost:8000/

# Web3Auth Configuration
# Get your Client ID from https://dashboard.web3auth.io
VITE_WEB3AUTH_CLIENT_ID=your_web3auth_client_id_here
VITE_WEB3AUTH_NETWORK=sapphire_devnet
